# Copy this file to terraform.tfvars and fill in.
# terraform.tfvars is gitignored.
#
# Generate jwt_secret with:
#   openssl rand -base64 48
#
# IMPORTANT: staging and production MUST use different jwt_secret values.

api_port  = 5600
web_port  = 5601
log_level = "debug"

jwt_secret = "REPLACE_ME_WITH_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS"
